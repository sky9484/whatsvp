# ─── Map ──────────────────────────────────────────────────────────────────────
# Get a free key at https://cloud.maptiler.com (add domain restriction)
# The app auto-selects light (streets-v2) / dark (streets-v2-dark) by theme.
# Without a key it falls back to CARTO Positron / Dark Matter (raster: no 3D).
NEXT_PUBLIC_MAPTILER_KEY=

# ─── Enoki / zkLogin (Sui) ────────────────────────────────────────────────────
# Create an app at https://portal.enoki.mystenlabs.com
# The public key is safe to expose; the secret key is server-only.
NEXT_PUBLIC_ENOKI_API_KEY=
ENOKI_SECRET_KEY=

# Google OAuth for zkLogin — create at https://console.cloud.google.com
# Authorised origins must include your Vercel domain and localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Apple OAuth for zkLogin (optional)
# APPLE_CLIENT_ID=

# Sui network: testnet | mainnet
NEXT_PUBLIC_SUI_NETWORK=testnet

# ─── Sui Move package (v2 Upgrade 3) ──────────────────────────────────────────
# Publish move/whatsvp to testnet (`sui client publish`) and paste the package ID.
# Passport / GuildBadge / cosmetic Avatar mints target this package, sponsored via Enoki.
NEXT_PUBLIC_WHATSVP_PACKAGE_ID=
# Shared Registry object id from the passport module's init (one-per-address mint).
NEXT_PUBLIC_PASSPORT_REGISTRY_ID=

# ─── Stamps (v3 P3 — check-in -> Stamp -> Passport) ────────────────────────────
# Publish move/whatsvp (now includes the stamp module) then run its init to get
# the Registry object id and the AdminCap object id transferred to your admin
# address; export that address's private key (bech32 `suiprivkey1...`, from
# `sui keytool export`) as STAMP_ADMIN_PRIVATE_KEY. Fund the admin address with
# a small amount of SUI — it pays its own gas for every Stamp mint (this is a
# backend hot wallet, separate from Enoki's per-user client-side sponsorship).
# Without these three set, check-ins still work fully — they're just recorded
# in Postgres only, no on-chain Stamp is minted.
STAMP_REGISTRY_ID=
STAMP_ADMIN_CAP_ID=
STAMP_ADMIN_PRIVATE_KEY=

# ─── Guild badges (pre-v4 P0 audit fix) ─────────────────────────────────────────
# guild.move's mint used to be client-callable with zero access control — it's
# now gated the same way as Stamps, minted server-side after /api/guilds/join
# records real membership. Reuses STAMP_ADMIN_PRIVATE_KEY as the signer (one
# backend address holds both AdminCaps); only these two object ids are new.
# Without them, joining a guild still works fully — no on-chain badge is minted.
GUILD_REGISTRY_ID=
GUILD_ADMIN_CAP_ID=

# ─── Push notifications (v3 P4 — PWA) ──────────────────────────────────────────
# Generate a pair with `npx web-push generate-vapid-keys`. Public key is safe to
# expose; the private key is server-only. Without these, the app (and the
# Notifications toggle in Settings) works fine — push just stays off.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@whatsvp.com

# ─── External-collection PFP verification (v2 Upgrade 4) ───────────────────────
# Get a free key at https://www.alchemy.com — used for read-only ownership checks
# (NFT API) and EVM signature verification (RPC). Server-only. Opt-in, power-user
# feature; without this key the link/verify flow returns 503 and the app is
# otherwise unaffected (external PFP is never required to onboard).
EVM_NFT_API_KEY=

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project settings → API at https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Never expose this key client-side — only used in server routes / cron jobs
SUPABASE_SERVICE_ROLE_KEY=
# Project Settings → API → JWT Settings → JWT Secret.
# Server-only — used to mint the session token so Postgres RLS recognises the user.
SUPABASE_JWT_SECRET=

# ─── Luma ─────────────────────────────────────────────────────────────────────
# Requires Luma Plus on the calendar you own and curate.
# Get API key at https://lu.ma/settings/developer
LUMA_API_KEY=
# The cal_* ID of your curated KL events calendar
LUMA_CALENDAR_ID=

# ─── Registration 2.0 (v4 P2) — guest claim emails ──────────────────────────────
# Get a free key at https://resend.com. Without it, guest registration still
# works fully — the claim link is shown directly in the success screen
# ("screenshot this") instead of emailed.
RESEND_API_KEY=
MAIL_FROM="WhatsVP <hello@whatsvp.com>"
# Used to build the claim link in the email. Falls back to the request's own
# origin if unset (fine for a single-domain deploy).
NEXT_PUBLIC_APP_URL=

# ─── Vercel Cron ──────────────────────────────────────────────────────────────
# Vercel passes this as `Authorization: Bearer <CRON_SECRET>` on cron requests.
# Set any random secret string here and in your Vercel env vars.
CRON_SECRET=
